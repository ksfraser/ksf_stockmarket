#
# default/common make settings are in $TOOLS/makedefaults
#include $(TOOLS)/makedefaults

#
# the following 3 lines are recommended (TARGET, SRCS, OBJS)
# and are regenerated by make defsrcs
TARGET=libksf_sql.a
SHAREDTARGET=libksf_sql.so
HSRCS=
SRCS=ksf_sql.c getSymbolList.c
OBJS=ksf_sql.o getSymbolList.o
INSTALLDIR=../lib
COMPFLAGS=-g -c -ggdb -ftest-coverage -pedantic -Wall -fPIC
#COMPFLAGS=-g -c -ggdb -ftest-coverage -pedantic -Ddebug -Wall -fPIC
LINKFLAGS=-lgcov
STATICARC=ar rcs
SHAREDARC=gcc -shared -Wl -soname
LIBDIR=-L../../src/lib
LIB=-lta_lib

#
# INCLUDEDIRS may be modified as required
INCLUDEDIRS=$(DEFAULTINCLUDEDIRS) -I../include -I../../ -I../../src/

all: $(TARGET)

,v.c:
	co $(SRCS)
.c.o:
	$(CC) $(COMPFLAGS) $(INCLUDEDIRS) $<

$(TARGET): $(OBJS)
	rm -f $(TARGET)
#	$(LD) $(TARGET) $(OBJS) $(LINKFLAGS)
#	$(CC) -o $(TARGET) $(OBJS) $(LINKFLAGS)
	$(STATICARC) $(TARGET) $(OBJS)
	$(SHAREDARC),$(SHAREDTARGET) -o $(SHAREDTARGET).1 $(OBJS)
	cp $(TARGET) $(SHAREDTARGET)* $(INSTALLDIR)

splint:
	splint $(INCLUDEDIRS) $(SRCS) -redef
	#splint $(INCLUDEDIRS) $(SRCS) -weak
	#splint $(INCLUDEDIRS) $(SRCS) +charintliteral
	#splint $(INCLUDEDIRS) $(SRCS) +charintliteral +export-header

clean:
	rm -f *.o

