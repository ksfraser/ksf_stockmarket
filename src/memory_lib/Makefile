#
# default/common make settings are in $TOOLS/makedefaults
#include $(TOOLS)/makedefaults

#
# the following 3 lines are recommended (TARGET, SRCS, OBJS)
# and are regenerated by make defsrcs
TARGET=libksf_memory.a
SHAREDTARGET=libksf_memory.so
HSRCS=
#HEXPORT=iyc002.h iyc005.h iyc008.h iyc009.h iyc011.h iyc012.h iyc014.h iyc015.h iyc020.h
SRCS=ksf_malloc.c malloc_memset.c
OBJS=ksf_malloc.o malloc_memset.o
INSTALLDIR=../lib
DFLAGS=-Wall
COMPFLAGS=-g -c -ggdb -ftest-coverage -pedantic -Ddebug -fPIC
LINKFLAGS=-lgcov
STATICARC=ar rcs
SHAREDARC=gcc -shared -Wl -soname

#
# INCLUDEDIRS may be modified as required
INCLUDEDIRS=$(DEFAULTINCLUDEDIRS) -I../include

all: $(TARGET)

,v.c:
	co $(SRCS)
.c.o:
	$(CC) $(COMPFLAGS) $(INCLUDEDIRS) $<

$(TARGET): $(OBJS)
	rm -f $(TARGET)
	$(STATICARC) $(TARGET) $(OBJS)
	$(SHAREDARC),$(SHAREDTARGET) -o $(SHAREDTARGET).1 $(OBJS)
	cp $(TARGET) $(SHAREDTARGET)* $(INSTALLDIR)
	cp *h ../include/

clean:
	rm -f *.o

