{
    "name": "ksf/stockmarket",
    "description": "Stock market analysis tool - portfolio tracking, backtesting, technical analysis",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "monolog/monolog": "^3.0",
        "vlucas/phpdotenv": "^5.5",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0",
        "mockery/mockery": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "Ksf\\StockMarket\\": "src/",
            "Ksf\\StockMarket\\Controller\\": "src/Controller/",
            "Ksf\\StockMarket\\Model\\": "src/Model/",
            "Ksf\\StockMarket\\Service\\": "src/Service/",
            "Ksf\\StockMarket\\TA\\": "src/TA/",
            "Ksf\\StockMarket\\Module\\": "src/Module/",
            "Ksf\\StockMarket\\View\\": "src/View/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ksf\\StockMarket\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
