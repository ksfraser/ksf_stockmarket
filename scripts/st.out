SELECT distinct(YahooCountry) FROM stockexchange    ORDER BY idstockexchange ASC 
SELECT * FROM stockinfo WHERE active='1' and stockexchange in (select idstockexchange from stockexchange where YahooCountry='Canada')   ORDER BY idstockinfo ASC LIMIT 0, 199
